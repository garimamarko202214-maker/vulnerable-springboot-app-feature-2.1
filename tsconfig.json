{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "types": ["node"]
  },
  "include": [
    "features/**/*.ts",
    "step-definitions/**/*.ts",
    "pages/**/*.ts",
    "utils/**/*.ts",
    "hooks/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "playwright-report", "test-results", "vulnerable-springboot-app-feature-2.1"]
}