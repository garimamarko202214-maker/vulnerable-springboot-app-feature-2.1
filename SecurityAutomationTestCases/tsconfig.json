{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@api/*": ["api/*"],
      "@utils/*": ["utils/*"],
      "@support/*": ["support/*"],
      "@hooks/*": ["hooks/*"]
    }
  },
  "include": [
    "features/**/*",
    "step-definitions/**/*.ts",
    "api/**/*.ts",
    "utils/**/*.ts",
    "hooks/**/*.ts",
    "support/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "reports", "playwright-report"]
}
